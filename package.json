{
  "name": "rekordbox-amigo-cli",
  "version": "0.1.0",
  "private": false,
  "description": "A safe, Amigo-style Rekordbox library audit and tagging CLI for DJs.",
  "type": "module",
  "bin": {
    "rb-amigo": "./dist/cli.js",
    "rekordbox-amigo": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:cli",
    "build:cli": "tsup src/cli.ts --format esm --target node20 --sourcemap --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "preview": "vite preview",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-xml-parser": "^5.8.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "table": "^6.9.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.12",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20"
  }
}
